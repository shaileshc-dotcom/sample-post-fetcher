# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- OpenAI (optional — powers prompt ranking + AI analysis) ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ---- SpeedyIndex (optional — powers the Index Checker) ----
SPEEDYINDEX_API_KEY=your-speedyindex-key

# ---- Google (Docs + Drive) ----
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_SHARED_DRIVE_ID=your-shared-drive-id
